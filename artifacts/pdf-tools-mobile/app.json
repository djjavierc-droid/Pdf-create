{
  "expo": {
    "name": "PDF Tools",
    "slug": "pdf-tools-mobile",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/images/icon.png",
    "scheme": "pdf-tools-mobile",
    "userInterfaceStyle": "automatic",
    "newArchEnabled": false,
    "splash": {
      "image": "./assets/images/icon.png",
      "resizeMode": "contain",
      "backgroundColor": "#312e81"
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/images/icon.png",
        "backgroundColor": "#312e81"
      },
      "package": "com.javiersooto.pdftools"
    },
    "web": {
      "favicon": "./assets/images/icon.png"
    },
    "plugins": [
      [
        "expo-router",
        {
          "origin": "https://replit.com/"
        }
      ],
      "expo-font",
      [
        "expo-image-picker",
        {
          "photosPermission": "La app necesita acceder a tus fotos para convertirlas a PDF."
        }
      ]
    ],
    "experiments": {
      "typedRoutes": true
    }
  }
}
